# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-a-new-one
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration (PostgreSQL)
# Format: postgres://user:password@host:port/database_name
DATABASE_URL=postgres://user:password@localhost:5432/django_pos

# Optional: If using a specific database provider like Heroku, Render, etc.
# The platform will typically set DATABASE_URL automatically
